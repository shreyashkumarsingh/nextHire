# ==========================================
# NextHire Environment Configuration
# ==========================================
# Copy this file to .env and update the values
# Generate secure keys: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Configuration
# Development (SQLite):
DATABASE_URL=sqlite:///nexthire.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://username:password@localhost:5432/nexthire

# Upload Configuration
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=pdf,docx,txt

# Email Configuration (for future use)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# AWS S3 Configuration (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# Redis Configuration (for Celery/Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/1
RATELIMIT_DEFAULT=100 per hour

# Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Pagination
RESUMES_PER_PAGE=20

# CORS Configuration (for production)
# Set to your frontend domain(s). Multiple domains separated by comma.
CORS_ORIGINS=http://localhost:3000
# For production:
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Logging
LOG_LEVEL=INFO

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
